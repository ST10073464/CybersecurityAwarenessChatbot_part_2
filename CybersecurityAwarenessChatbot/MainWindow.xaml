<Window x:Class="CybersecurityAwarenessChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CybersecurityAwarenessChatbot"
        Title="SecureWin Cybersecurity Assistant"
        mc:Ignorable="d"
        Height="950"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#07111F"
        WindowState="Maximized">

    <!-- ========================================================= -->
    <!-- RESOURCES -->
    <!-- ========================================================= -->

    <Window.Resources>

        <!-- Rounded Cyber Button -->
        <Style x:Key="CyberButton" TargetType="Button">

            <Setter Property="Background" Value="#00C2FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

        </Style>

    </Window.Resources>

    <!-- ========================================================= -->
    <!-- MAIN GRID -->
    <!-- ========================================================= -->

    <Grid Margin="15">

        <Grid.RowDefinitions>

            <!-- HEADER -->
            <RowDefinition Height="320"/>

            <!-- CONTENT -->
            <RowDefinition Height="*"/>

            <!-- INPUT -->
            <RowDefinition Height="130"/>

        </Grid.RowDefinitions>

        <!-- ========================================================= -->
        <!-- HEADER AREA -->
        <!-- ========================================================= -->

        <Border Grid.Row="0"
                Background="#10263A"
                CornerRadius="25"
                Padding="25"
                BorderBrush="#00C2FF"
                BorderThickness="2">

            <Grid>

                <Grid.ColumnDefinitions>

                    <!-- ASCII -->
                    <ColumnDefinition Width="3*"/>

                    <!-- FEATURES -->
                    <ColumnDefinition Width="2*"/>

                </Grid.ColumnDefinitions>

                <!-- ================================================= -->
                <!-- ASCII SECTION -->
                <!-- ================================================= -->

                <StackPanel Grid.Column="0">

                    <TextBlock Text="🔒 SECUREWIN CYBERSECURITY ASSISTANT 🔒"
                               Foreground="#00E5FF"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <!-- ASCII ART -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Height="218">

                        <TextBlock x:Name="AsciiArtText"
                                   Foreground="#7DF9FF"
                                   FontFamily="Consolas"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   TextWrapping="NoWrap"/>

                    </ScrollViewer>

                </StackPanel>

                <!-- ================================================= -->
                <!-- FEATURE DASHBOARD -->
                <!-- ================================================= -->

                <Border Grid.Column="1"
                        Margin="15,0,0,0"
                        Background="#0D1B2A"
                        CornerRadius="20"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="🛡️ AVAILABLE FEATURES"
                                   Foreground="#00E5FF"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="✅ Password Safety Tips"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Phishing Detection"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Scam Awareness"
                                   Foreground="White"
                                   FontSize="18"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Malware Protection"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ VPN Security"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Ransomware Safety"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Sentiment Detection"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Smart Follow-up Conversations"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="✅ Emoji Messaging"
                                   Foreground="White"
                                   FontSize="16"
                                   Margin="0,5"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- ========================================================= -->
        <!-- CHAT SECTION -->
        <!-- ========================================================= -->

        <Border Grid.Row="1"
                Margin="0,15"
                Background="#0D1B2A"
                CornerRadius="25"
                Padding="15"
                BorderBrush="#00C2FF"
                BorderThickness="1.5">

            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatPanel"/>

            </ScrollViewer>

        </Border>

        <!-- ========================================================= -->
        <!-- INPUT SECTION -->
        <!-- ========================================================= -->

        <Border Grid.Row="2"
                Background="#10263A"
                CornerRadius="25"
                Padding="15">

            <Grid>

                <Grid.ColumnDefinitions>

                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>

                </Grid.ColumnDefinitions>

                <!-- ================================================= -->
                <!-- LEFT SIDE -->
                <!-- ================================================= -->

                <StackPanel Grid.Column="0">

                    <!-- USER INPUT -->
                    <TextBox x:Name="UserInputTextBox"
                             Height="50"
                             FontSize="18"
                             Padding="10"
                             Foreground="White"
                             Background="#1B263B"
                             BorderBrush="#00C2FF"
                             CaretBrush="White"
                             KeyDown="UserInputTextBox_KeyDown"/>

                    <!-- ================================================= -->
                    <!-- EMOJIS -->
                    <!-- ================================================= -->

                    <WrapPanel Margin="0,10,0,0">

                        <Button Content="😊"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="😎"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="😂"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="🤖"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="🔒"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="🛡️"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="⚠️"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="💻"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="🎣"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                        <Button Content="🚨"
                                Width="50"
                                Height="40"
                                FontSize="22"
                                Click="Emoji_Click"/>

                    </WrapPanel>

                </StackPanel>

                <!-- ================================================= -->
                <!-- SEND BUTTON -->
                <!-- ================================================= -->

                <Button Grid.Column="1"
                        x:Name="SendButton"
                        Content="📨 SEND"
                        Style="{StaticResource CyberButton}"
                        Height="70"
                        Width="100"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Click="SendButton_Click"/>

            </Grid>

        </Border>

    </Grid>

</Window>

